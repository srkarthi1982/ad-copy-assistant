---
import AppShell from "../layouts/AppShell.astro";
import { AvButton, AvCard, AvContainer } from "@ansiversa/components";
import {
  AD_COPY_CHANNELS,
  AD_COPY_STATUSES,
  archiveAdCopyForUser,
  createAdCopyForUser,
  listAdCopiesForUser,
  parseAdCopyInput,
  restoreAdCopyForUser,
  summarizeAdCopiesForUser,
  toggleAdCopyFavoriteForUser,
} from "../lib/adCopies";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/");

const searchParams = Astro.url.searchParams;
const filters = {
  search: searchParams.get("search") ?? "",
  channel: (searchParams.get("channel") ?? "") as "" | (typeof AD_COPY_CHANNELS)[number],
  status: (searchParams.get("status") ?? "") as "" | (typeof AD_COPY_STATUSES)[number],
  favoriteOnly: searchParams.get("favorites") === "true",
  archived: searchParams.get("archived") === "true",
};

let formError = "";
let createValues = {
  title: "",
  campaignName: "",
  channel: "general",
  audience: "",
  offer: "",
  notes: "",
  status: "draft",
};

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const intent = String(formData.get("intent") ?? "");
  const idRaw = String(formData.get("id") ?? "");

  try {
    if (intent === "create") {
      createValues = {
        title: String(formData.get("title") ?? ""),
        campaignName: String(formData.get("campaignName") ?? ""),
        channel: String(formData.get("channel") ?? "general"),
        audience: String(formData.get("audience") ?? ""),
        offer: String(formData.get("offer") ?? ""),
        notes: String(formData.get("notes") ?? ""),
        status: String(formData.get("status") ?? "draft"),
      };

      const createdRecordId = (
        await createAdCopyForUser(
        user.id,
        parseAdCopyInput({
          title: formData.get("title"),
          campaignName: formData.get("campaignName"),
          channel: formData.get("channel"),
          audience: formData.get("audience"),
          offer: formData.get("offer"),
          notes: formData.get("notes"),
          status: formData.get("status"),
        }),
        )
      ).id;

      return Astro.redirect(`/app/copies/${createdRecordId}`);
    }

    const id = Number.parseInt(idRaw, 10);
    if (!Number.isFinite(id)) {
      return Astro.redirect("/app");
    }

    if (intent === "toggleFavorite") {
      await toggleAdCopyFavoriteForUser(user.id, id);
      return Astro.redirect("/app");
    }
    if (intent === "archive") {
      await archiveAdCopyForUser(user.id, id);
      return Astro.redirect("/app");
    }
    if (intent === "restore") {
      await restoreAdCopyForUser(user.id, id);
      return Astro.redirect("/app");
    }
  } catch (error) {
    formError = error instanceof Error ? error.message : "Unable to save ad copy.";
  }
}

const adCopies = await listAdCopiesForUser(user.id, filters);
const summary = await summarizeAdCopiesForUser(user.id);
---

<AppShell title="Ad Copy Workspace" description="Protected workspace for structured ad copy records.">
  <main class="py-10">
    <AvContainer>
      <div class="av-auth-stack-lg">
        <section class="flex flex-wrap items-end justify-between gap-4">
          <div class="av-auth-stack-xs">
            <p class="av-kicker">Protected workspace</p>
            <h1 class="av-section-title">Your ad copy library</h1>
            <p class="av-text-soft">
              Create campaign shells, add multiple variants inside each record, and keep the strongest copy easy to revisit.
            </p>
          </div>
          <AvButton href="#create">Create Record</AvButton>
        </section>

        <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
          <AvCard variant="soft"><p class="av-kicker">Total</p><h2 class="av-card-heading">{summary.total}</h2></AvCard>
          <AvCard variant="soft"><p class="av-kicker">Active</p><h2 class="av-card-heading">{summary.active}</h2></AvCard>
          <AvCard variant="soft"><p class="av-kicker">Favorites</p><h2 class="av-card-heading">{summary.favorites}</h2></AvCard>
          <AvCard variant="soft"><p class="av-kicker">Archived</p><h2 class="av-card-heading">{summary.archived}</h2></AvCard>
        </section>

        <section class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
          <AvCard variant="soft" className="av-auth-stack-md">
            <div class="av-section-header">
              <h2 class="av-section-title">Browse your records</h2>
              <p class="av-section-lead">Search campaign context and saved variant copy without turning the workspace into analytics software.</p>
            </div>

            <form method="GET" class="grid gap-3 md:grid-cols-2 xl:grid-cols-5">
              <input type="search" name="search" value={filters.search} placeholder="Search title, campaign, headline, variant copy" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white xl:col-span-2" />
              <select name="channel" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white">
                <option value="">All channels</option>
                {AD_COPY_CHANNELS.map((channel) => <option value={channel} selected={filters.channel === channel}>{channel}</option>)}
              </select>
              <select name="status" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white">
                <option value="">All statuses</option>
                {AD_COPY_STATUSES.map((status) => <option value={status} selected={filters.status === status}>{status}</option>)}
              </select>
              <select name="favorites" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white">
                <option value="false" selected={!filters.favoriteOnly}>All records</option>
                <option value="true" selected={filters.favoriteOnly}>Favorites only</option>
              </select>
              <select name="archived" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white">
                <option value="false" selected={!filters.archived}>Active view</option>
                <option value="true" selected={filters.archived}>Archived view</option>
              </select>
              <div class="flex flex-wrap gap-2 xl:col-span-5">
                <button class="rounded-lg bg-white px-4 py-2 text-sm font-medium text-slate-950">Apply Filters</button>
                <a href="/app" class="rounded-lg border border-white/15 px-4 py-2 text-sm text-slate-200">Reset</a>
              </div>
            </form>

            <div class="space-y-3">
              {adCopies.length ? adCopies.map((record) => (
                <article class="rounded-xl border border-white/10 bg-slate-950/70 p-4">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div class="av-auth-stack-xxs">
                      <a href={`/app/copies/${record.id}`} class="text-lg font-medium text-white hover:text-emerald-300">{record.title}</a>
                      <p class="text-sm text-slate-400">
                        {[record.campaignName, record.channel, record.status].filter(Boolean).join(" · ")}
                      </p>
                      <p class="text-xs text-slate-500">
                        {record.variantCount} variant{record.variantCount === 1 ? "" : "s"} · Updated {new Date(record.updatedAt).toLocaleDateString()}
                      </p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                      {record.isFavorite ? <span class="rounded-full border border-amber-300/30 px-2 py-1 text-xs text-amber-200">Record favorite</span> : null}
                      {record.hasFavoriteVariant ? <span class="rounded-full border border-emerald-300/30 px-2 py-1 text-xs text-emerald-200">Favorite variant</span> : null}
                      {record.isArchived ? <span class="rounded-full border border-white/15 px-2 py-1 text-xs text-slate-300">Archived</span> : null}
                    </div>
                  </div>
                  <p class="mt-3 text-sm text-slate-300">
                    {record.previewVariant
                      ? `${record.previewVariant.label}: ${record.previewVariant.headline ?? record.previewVariant.primaryText ?? "Saved variant"}`
                      : "No variants saved yet. Open the detail page to add the first one."}
                  </p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    <form method="POST">
                      <input type="hidden" name="intent" value="toggleFavorite" />
                      <input type="hidden" name="id" value={record.id} />
                      <button type="submit" class="rounded-lg border border-white/15 px-3 py-1.5 text-xs text-slate-200">{record.isFavorite ? "Unfavorite Record" : "Favorite Record"}</button>
                    </form>
                    {!record.isArchived ? (
                      <form method="POST">
                        <input type="hidden" name="intent" value="archive" />
                        <input type="hidden" name="id" value={record.id} />
                        <button type="submit" class="rounded-lg border border-white/15 px-3 py-1.5 text-xs text-slate-200">Archive</button>
                      </form>
                    ) : (
                      <form method="POST">
                        <input type="hidden" name="intent" value="restore" />
                        <input type="hidden" name="id" value={record.id} />
                        <button type="submit" class="rounded-lg border border-white/15 px-3 py-1.5 text-xs text-slate-200">Restore</button>
                      </form>
                    )}
                    <a href={`/app/copies/${record.id}`} class="rounded-lg border border-emerald-400/25 px-3 py-1.5 text-xs text-emerald-200">Open Detail</a>
                  </div>
                </article>
              )) : (
                <div class="rounded-xl border border-dashed border-white/15 p-8 text-center">
                  <p class="text-white">No ad copy records match the current filters.</p>
                  <p class="mt-2 text-sm text-slate-400">This is a personal ad copy workspace. Start by creating one record, then add variants on the detail page. No AI generation is implied here.</p>
                </div>
              )}
            </div>
          </AvCard>

          <AvCard id="create" className="av-auth-stack-md">
            <div class="av-section-header">
              <h2 class="av-section-title">Create a record</h2>
              <p class="av-section-lead">Start with the campaign context shell, then add one or more variants on the detail page.</p>
            </div>
            {formError ? <p class="rounded-lg border border-red-400/20 bg-red-500/10 px-3 py-2 text-sm text-red-200">{formError}</p> : null}
            <form method="POST" class="av-auth-stack-sm">
              <input type="hidden" name="intent" value="create" />
              <input required name="title" value={createValues.title} placeholder="Title" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white" />
              <input name="campaignName" value={createValues.campaignName} placeholder="Campaign or product" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white" />
              <select name="channel" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white">
                {AD_COPY_CHANNELS.map((channel) => <option value={channel} selected={createValues.channel === channel}>{channel}</option>)}
              </select>
              <input name="audience" value={createValues.audience} placeholder="Audience" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white" />
              <input name="offer" value={createValues.offer} placeholder="Offer" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white" />
              <textarea name="notes" rows="3" placeholder="Record notes" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white">{createValues.notes}</textarea>
              <select name="status" class="rounded-lg border border-white/10 bg-slate-950 px-3 py-2 text-sm text-white">
                {AD_COPY_STATUSES.map((status) => <option value={status} selected={createValues.status === status}>{status}</option>)}
              </select>
              <button class="rounded-lg bg-emerald-400 px-4 py-2 text-sm font-medium text-slate-950">Create record</button>
            </form>
          </AvCard>
        </section>
      </div>
    </AvContainer>
  </main>
</AppShell>
