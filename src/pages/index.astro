---
import AppShell from "../layouts/AppShell.astro";
import { AvContainer, AvButton, AvCard } from "@ansiversa/components";
import { appMeta } from "../app.meta";
---

<AppShell title={`${appMeta.name} – Ansiversa`} description={appMeta.description}>
  <section class="av-hero">
    <AvContainer size="narrow" className="av-hero__content--narrow">
      <div class="av-hero__content">
        <div class="av-kicker">
          <span>Marketing · Ansiversa Mini App</span>
        </div>
        <h1 class="av-gradient-text">{appMeta.name}</h1>
        <p>Draft premium, campaign-ready ad copy in minutes with structured A/B/C variants.</p>
      </div>
      <div class="av-cta-row">
        <AvButton href="/app">Open app</AvButton>
      </div>
    </AvContainer>
  </section>

  <section class="av-section">
    <AvContainer size="narrow">
      <AvCard className="space-y-4 p-6">
        <h2 class="av-section-title">What you can do in V1</h2>
        <ul class="space-y-2 text-slate-300 list-disc list-inside">
          <li>Capture campaign basics, platform context, and tone.</li>
          <li>Edit three polished ad variants with instant switching.</li>
          <li>Review a live structured preview while drafting.</li>
          <li>Copy one variant or the full campaign copy set.</li>
          <li>Keep progress locally and reset safely when starting fresh.</li>
        </ul>
      </AvCard>
    </AvContainer>
  </section>
</AppShell>
